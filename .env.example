# Backend
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=info

# PostgreSQL container
POSTGRES_DB=grp9_stats
POSTGRES_USER=grp9_stats
POSTGRES_PASSWORD=change_me

# Backend DB connection used by the API container
DATABASE_URL=postgres://grp9_stats:change_me@postgres:5432/grp9_stats

# Initial local Arma ingest token seed.
# Change this before first real deployment and keep the real value out of Git.
GRP9_SERVER_KEY=main
GRP9_SERVER_NAME=Main Server
GRP9_MACHINE_TOKEN=change_me_local_machine_token
